rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: only the verified admin email may write
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "Gimellicar7@gmail.com"
        && request.auth.token.email_verified == true;
    }

    // Cars: public read, admin-only write
    match /cars/{carId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins collection: admin-only read/write
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    // Bookings: disabled entirely (no longer in use)
    match /bookings/{bookingId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
